API_PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=eds_lab
SSL_MODE=disable

DOCUMENT_STORAGE_PATH=data/uploads

SERVER_PRIVATE_KEY_PATH=data/keys/server_private.pem
SERVER_PUBLIC_KEY_PATH=data/keys/server_public.pem
# Alternative to *_PATH:
# SERVER_PRIVATE_KEY_PEM="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----"
# SERVER_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=server@example.com
# SMTP_USER=
# SMTP_PASSWORD=

POSTGRES_CONTAINER_NAME=eds_lab_postgres
MAILPIT_CONTAINER_NAME=eds_lab_mailpit
MAILPIT_UI_PORT=8025
